72\u5217\u5169\u6b21\u6b78\u56de\u4e26\u91cd\u5efa\u8056\u6bbf\u7684\u6b77\u53f2,\u900f\u904e\u9019\u6bb5\u6b77\u53f2\u53ef\u4ee5\u8b93\u6211\u5011\u770b\u5230\u795e\u7684\u4fe1\u5be6\u548c\u6148\u611b\u3002\u4ee5\u8272\u5217\u6c11\u91cd\u5efa\u8056\u6bbf--\u795e\u7684\u5bb6\u7684\u904e\u7a0b,\u5c0d\u65bc\u6211\u5011\u4eca\u5929\u5efa\u9020\u6559\u6703--\u795e\u7684\u5bb6\u662f\u5f88\u597d\u7684\u555f\u767c\u548c\u5e6b\u52a9,\u8b93\u6211\u5011\u4e00\u8d77\u4f86\u85c9\u8457\u8996\u983b,\u8a0e\u8ad6\u4f86\u5b78\u7fd2\u9019\u5377\u66f8\u3002","title":"\u4ee5\u65af\u62c9\u8a18"},{"location":"%E4%BB%A5%E6%96%AF%E6%8B%89%E8%A8%98/#_1","text":"","title":"\u4ee5\u65af\u62c9\u8a18"},{"location":"%E4%BB%A5%E6%96%AF%E6%8B%89%E8%A8%98/#_2","text":"\u4ee5\u8272\u5217\u7684\u80cc\u7d04\u5c0e\u81f4\u4e86\u4ea1\u570b\u548c\u88ab\u64c4,\u7136\u800c\u795e\u65e9\u5df2\u9810\u8a00\u4e86\u4ee5\u8272\u5217\u7684\u6b78\u56de,\u795e\u7684\u62c6\u6bc0\u70ba\u7684\u662f\u8981\u91cd\u5efa\u4ed6\u7684\u5b50\u6c11\u4ee5\u8272\u5217\u4ee5\u65af\u62c9\u8a18\u5c31\u662f\u4ee5\u56de\u61b6\u9304\u7684\u5f62\u5f0f\u8a18\u8f09\u4e86\u4ee5\u8272\u5217\u5169\u6b21\u6b78\u56de\u4e26\u91cd\u5efa\u8056\u6bbf\u7684\u6b77\u53f2,\u900f\u904e\u9019\u6bb5\u6b77\u53f2\u53ef\u4ee5\u8b93\u6211\u5011\u770b\u5230\u795e\u7684\u4fe1\u5be6\u548c\u6148\u611b\u3002\u4ee5\u8272\u5217\u6c11\u91cd\u5efa\u8056\u6bbf--\u795e\u7684\u5bb6\u7684\u904e\u7a0b,\u5c0d\u65bc\u6211\u5011\u4eca\u5929\u5efa\u9020\u6559\u6703--\u795e\u7684\u5bb6\u662f\u5f88\u597d\u7684\u555f\u767c\u548c\u5e6b\u52a9,\u8b93\u6211\u5011\u4e00\u8d77\u4f86\u85c9\u8457\u8996\u983b,\u8a0e\u8ad6\u4f86\u5b78\u7fd2\u9019\u5377\u66f8\u3002","title":"\u8ab2\u7a0b\u7c21\u4ecb"},{"location":"%E5%90%8C%E5%B7%A5%E8%A8%93%E7%B7%B4/","text":"\u540c\u5de5\u8a13\u7df4 \u8ab2\u7a0b\u7c21\u4ecb \u88dd\u5099\u65b0\u4efb\u7684\u5c0f\u7d44\u9577\u8207\u6559\u6703\u540c\u5de5\uff0c\u6309\u8457\u795e\u6240\u8cdc\u7d66\u500b\u4eba\u7684\u547c\u53ec\u8207\u6069\u8cdc\uff0c\u4f5c\u5f